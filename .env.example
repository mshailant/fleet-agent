# ── FleetOps Agent — Variables de entorno ──────────────────────────────────
# Copiá este archivo como .env y completá con los valores del panel

# URL WebSocket del panel (copiala del tab Info del cliente)
PANEL_WS_URL=wss://panel.monitoreocinexo.com.ar/ws/agent

# ID y token del cliente (copiá del tab Info del panel)
CLIENT_ID=c_XXXXXXXXXX
AGENT_TOKEN=tok-XXXXXXXXXX

# Ruta al docker-compose.yml de la aplicación del cliente
COMPOSE_FILE=/opt/app/docker-compose.yml

# Intervalo de envío de métricas en ms (default: 30000)
# METRICS_INTERVAL=30000
