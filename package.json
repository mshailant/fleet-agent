{
  "name": "cinexo-fleet-agent",
  "version": "2.0.0",
  "description": "FleetOps Agent — instalar en cada servidor cliente",
  "main": "dist/index.js",
  "scripts": {
    "build":     "tsc",
    "start":     "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "watch":     "ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "dependencies": {
    "dockerode": "^4.0.4",
    "dotenv":    "^16.4.7",
    "ws":        "^8.18.1"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.32",
    "@types/node":      "^22.13.0",
    "@types/ws":        "^8.5.14",
    "ts-node":          "^10.9.2",
    "ts-node-dev":      "^2.0.0",
    "typescript":       "^5.8.2"
  }
}
